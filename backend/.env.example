# Environment variables for KrishiMane backend
# Copy this file to .env and fill in your values

GOOGLE_API_KEY=your-google-api-key-here
JWT_SECRET=krishimane-jwt-secret-change-in-production-2024

# Database — PostgreSQL (set via docker-compose, override here for local dev)
# DATABASE_URL is set in docker-compose.yml environment
# For local dev without Docker: DATABASE_URL=sqlite:///./krishimane.db
DATABASE_URL=postgresql://krishimane:krishimane123@localhost:5432/krishimane

# Razorpay — Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
